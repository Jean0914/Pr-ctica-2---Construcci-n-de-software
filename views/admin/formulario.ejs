<%- include('../partials/header') %>

<div class="card" style="max-width: 800px; margin: 0 auto;">
  <h2 style="margin-top:0"><%= accion %> Post</h2>
  
  <% if (error) { %>
    <div class="alert alert-error">
      <%= error %>
    </div>
  <% } %>

  <form action="<%= accion === 'Crear' ? '/admin/posts/nuevo' : '/admin/posts/' + post.id + '/editar' %>" method="POST">
    <div class="form-group">
      <label for="titulo">Título del Post</label>
      <input type="text" id="titulo" name="titulo" value="<%= post ? post.titulo : '' %>">
    </div>
    
    <div class="form-group">
      <label for="contenido">Contenido</label>
      <textarea id="contenido" name="contenido"><%= post ? post.contenido : '' %></textarea>
    </div>
    
    <div style="display: flex; gap: 1rem; margin-top: 2rem;">
      <a href="/admin" class="btn btn-secondary">Cancelar</a>
      <button type="submit" class="btn btn-primary">Guardar Cambios</button>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
