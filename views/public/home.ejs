<%- include('../partials/header') %>

<h1 class="text-center" style="font-size: 2.5rem; margin-bottom: 3rem; background: linear-gradient(90deg, #60a5fa, #c084fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Últimas Publicaciones</h1>

<% if (posts.length === 0) { %>
  <div class="empty-state">
    <h2>Aún no hay publicaciones</h2>
    <p>Vuelve más tarde para leer nuestros artículos.</p>
  </div>
<% } else { %>
  <% posts.forEach(post => { %>
    <article class="card">
      <h2 class="card-title"><%= post.titulo %></h2>
      <div class="card-meta">
        Publicado el <%= new Date(post.fecha_creacion).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
      </div>
      <div class="card-content"><%= post.contenido %></div>
    </article>
  <% }) %>
<% } %>

<%- include('../partials/footer') %>
